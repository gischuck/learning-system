# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库
DB_PATH=./data/william_learning.db
DB_SYNC_MODE=alter

# JWT配置
# JWT_SECRET 用于加密用户登录令牌，请设置一个随机的字符串
# 生成方式: openssl rand -hex 32
# 或自己编一个足够长的随机字符串
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# 同步配置
AUTO_SYNC=false

# AI 配置
# 支持任何 OpenAI 兼容接口，修改 ENDPOINT 和 MODEL 即可
# 
# OpenAI: https://api.openai.com/v1
# 阿里云百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek: https://api.deepseek.com/v1
# 智谱AI: https://open.bigmodel.cn/api/paas/v4
# Moonshot: https://api.moonshot.cn/v1
# 本地(Ollama): http://localhost:11434/v1
AI_API_KEY=your-api-key-here
AI_API_ENDPOINT=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Google 同步 (gog)
# GOG_KEYRING_PASSWORD=your-keyring-password

# Google Sheets 同步 (必须配置)
# 从 Google Sheets URL 中获取: https://docs.google.com/spreadsheets/d/YOUR_SHEETS_ID/edit
GOOGLE_SHEETS_ID=your-google-sheets-id-here
GOOGLE_ACCOUNT=your-email@gmail.com

# Google Docs 同步 (可选)
GOOGLE_DOCS_NAME=育儿经验笔记